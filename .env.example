# Set to "true" once the app is live on the stores. While "false" (or unset),
# the site shows a waitlist form instead of download buttons.
NEXT_PUBLIC_IS_APP_PUBLISHED=false

# Store URLs — only used once NEXT_PUBLIC_IS_APP_PUBLISHED is "true".
# Leave empty to disable the corresponding store button ("Available soon").
NEXT_PUBLIC_PLAYSTORE_URL=
NEXT_PUBLIC_APPSTORE_URL=

# Supabase (same project as teleprompter-app)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
